{
    "version": 2,
    "builds": [
        {
            "src": "api/index.py",
            "use": "@vercel/python"
        },
        {
            "src": "static/**",
            "use": "@vercel/static"
        },
        {
            "src": "v3-frontend/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/static/(.*)",
            "dest": "/static/$1"
        },
        {
            "src": "/auth/(.*)",
            "dest": "api/index.py"
        },
        {
            "src": "/login",
            "dest": "api/index.py"
        },
        {
            "src": "/logout",
            "dest": "api/index.py"
        },
        {
            "src": "/dashboard",
            "dest": "api/index.py"
        },
        {
            "src": "/dashboard_data",
            "dest": "api/index.py"
        },
        {
            "src": "/reports",
            "dest": "api/index.py"
        },
        {
            "src": "/reports_data",
            "dest": "api/index.py"
        },
        {
            "src": "/health",
            "dest": "api/index.py"
        },
        {
            "src": "/live/(.*)",
            "dest": "api/index.py"
        },
        {
            "src": "/search/(.*)",
            "dest": "api/index.py"
        },
        {
            "src": "/download/(.*)",
            "dest": "api/index.py"
        },
        {
            "src": "/",
            "dest": "api/index.py"
        },
        {
            "src": "/v3-frontend/(.*)",
            "dest": "/v3-frontend/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/v3-frontend/index.html"
        }
    ]
}