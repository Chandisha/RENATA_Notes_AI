{
    "version": 2,
    "rewrites": [
        {
            "source": "/health",
            "destination": "/api/index.py"
        },
        {
            "source": "/login",
            "destination": "/api/index.py"
        },
        {
            "source": "/logout",
            "destination": "/api/index.py"
        },
        {
            "source": "/auth/(.*)",
            "destination": "/api/index.py"
        },
        {
            "source": "/dashboard_data",
            "destination": "/api/index.py"
        },
        {
            "source": "/reports_data",
            "destination": "/api/index.py"
        },
        {
            "source": "/search/(.*)",
            "destination": "/api/index.py"
        },
        {
            "source": "/live/(.*)",
            "destination": "/api/index.py"
        },
        {
            "source": "/download/(.*)",
            "destination": "/api/index.py"
        },
        {
            "source": "/static/(.*)",
            "destination": "/static/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/v3-frontend/$1"
        }
    ]
}